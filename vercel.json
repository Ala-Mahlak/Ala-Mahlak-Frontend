{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ala-mahlak.runasp.net/api/:path*"
    },
    {
      "source": "/hubs/:path*",
      "destination": "https://ala-mahlak.runasp.net/hubs/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
